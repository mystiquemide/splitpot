# EVM JSON-RPC for WDK — must match the chain of the USDt token
# Default in code (if unset): https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_EVM_RPC_URL=https://ethereum-rpc.publicnode.com

# Canonical site URL (production). Invite links prefer this in production builds.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- On-chain USDt (optional) — required for on-chain stakes/payouts ---
# Ethereum mainnet USDT (6 decimals). Do not pair this address with a Sepolia RPC.
NEXT_PUBLIC_USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
NEXT_PUBLIC_USDT_DECIMALS=6
NEXT_PUBLIC_USDT_SYMBOL=USDt
NEXT_PUBLIC_CHAIN_NAME=Ethereum
NEXT_PUBLIC_EXPLORER_TX_URL=https://etherscan.io/tx/

# Sepolia example (use a Sepolia ERC-20 + Sepolia RPC together):
# NEXT_PUBLIC_EVM_RPC_URL=https://sepolia.drpc.org
# NEXT_PUBLIC_USDT_ADDRESS=0xYourSepoliaToken
# NEXT_PUBLIC_CHAIN_NAME=Sepolia
# NEXT_PUBLIC_EXPLORER_TX_URL=https://sepolia.etherscan.io/tx/
